APP_NAME=dawenzhang
APP_VERSION=0.1.0
ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Names exposed by the existing ai_tag_fix_default Docker network.
MYSQL_HOST=ai_tag_fix_mysql
MYSQL_PORT=3306
MYSQL_DATABASE=dawenzhang
MYSQL_USER=dawenzhang_app
MYSQL_PASSWORD=change-me
REDIS_HOST=ai_tag_fix_redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
REDIS_KEY_PREFIX=dawenzhang:


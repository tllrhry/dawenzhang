APP_NAME=dawenzhang
APP_VERSION=0.1.0
ENVIRONMENT=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost,http://127.0.0.1

# docker-compose builds DATABASE_URL from the POSTGRES_* values below and
# points the backend at the `db` service; override here only if needed.
POSTGRES_USER=dawenzhang
POSTGRES_PASSWORD=dawenzhang
POSTGRES_DB=dawenzhang
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=30

UPLOAD_DIR=/data/uploads
EXPORT_DIR=/data/exports

# Host directory holding the raw catalog Excel; mounted read-only at /catalog.
CATALOG_HOST_DIR=./国民经济
NATIONAL_ECONOMY_CATALOG_PATH=/catalog/国民经济行业分类V1-0814.xlsx

HTTP_CONNECT_TIMEOUT_SECONDS=10

SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
SILICONFLOW_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
EMBEDDING_DIMENSION=4096
SILICONFLOW_TIMEOUT_SECONDS=30
SILICONFLOW_EMBEDDING_BATCH_SIZE=32

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=120

CLASSIFICATION_TIMEOUT_SECONDS=180

HTTP_PORT=8080
APP_DATA_DIR=./data
DB_DATA_DIR=./data/pgdata

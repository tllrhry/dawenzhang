APP_NAME=dawenzhang
APP_VERSION=0.1.0
ENVIRONMENT=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL + pgvector is the only supported database (psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://dawenzhang:dawenzhang@127.0.0.1:5432/dawenzhang
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=30

UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports

# Raw GB/T 4754-2017 catalog Excel (mounted, never committed).
NATIONAL_ECONOMY_CATALOG_PATH=./国民经济/国民经济行业分类V1-0814.xlsx

# Shared HTTP connect timeout for cloud model clients.
HTTP_CONNECT_TIMEOUT_SECONDS=10

# SiliconFlow: embedding + rerank.
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
SILICONFLOW_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
EMBEDDING_DIMENSION=4096
SILICONFLOW_TIMEOUT_SECONDS=30
SILICONFLOW_EMBEDDING_BATCH_SIZE=32

# DeepSeek: constrained single-result classification.
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=120

# End-to-end synchronous classification budget (keep nginx/uvicorn >= this).
CLASSIFICATION_TIMEOUT_SECONDS=180

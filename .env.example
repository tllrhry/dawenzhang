APP_NAME=dawenzhang
APP_VERSION=0.1.0
ENVIRONMENT=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Existing MySQL 8 instance; this value is intentionally fixed for isolation.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=dawenzhang
MYSQL_USER=dawenzhang_app
MYSQL_PASSWORD=change-me

# Existing Redis 7 instance; db0 belongs to ai_tag_fix.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
REDIS_KEY_PREFIX=dawenzhang:

# Optional; no AI service is required for the foundation.
AI_BASE_URL=
AI_API_KEY=


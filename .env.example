APP_NAME=dawenzhang
APP_VERSION=0.1.0
ENVIRONMENT=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Single-process demonstration storage. Use absolute /data paths in Docker.
DATABASE_URL=sqlite:///./data/dawenzhang.db
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports

# Optional external model API. No local model service is started.
AI_BASE_URL=
AI_API_KEY=
AI_CONNECT_TIMEOUT_SECONDS=10
AI_READ_TIMEOUT_SECONDS=90
